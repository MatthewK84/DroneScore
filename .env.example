# DroneSmoke environment. Copy to .env for local work.
# Railway injects PORT and DATABASE_URL automatically.

# --- Access (required) ---
# Two shared passwords. Anyone with the scorer password can log
# engagements. Anyone with the admin password can edit records,
# close the day, and manage reports. Use long, distinct values.
SCORER_PASSWORD=change-me-scorer
ADMIN_PASSWORD=change-me-admin
# Viewers get the read-only Open View: every page, no editing.
VIEWER_PASSWORD=change-me-viewer

# VITE_APP_MODE is a build-time flag, not a server variable. Leave it unset
# for the ops console. Set it to "board" only on the read-only board service
# (Railway) or inline when running the board locally:
#   VITE_APP_MODE=board npm run dev -- --port 3002

# Signs session cookies. Use 32+ random characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Database ---
# Local example. On Railway this is provided by the Postgres plugin.
DATABASE_URL=postgres://dsuser:dspass@127.0.0.1:5432/dronesmoke
# Set true for managed Postgres that requires SSL. Railway's internal
# connection does not, so leave false when using DATABASE_URL from the
# Postgres plugin over the private network.
DATABASE_SSL=false

# --- Range defaults (optional) ---
# Seed values for each new operational day. Coordinates drive the
# weather lookup and sunrise/sunset times in the report.
DEFAULT_LOCATION_NAME=Poinsett Range, Shaw AFB, SC
DEFAULT_LATITUDE=33.85
DEFAULT_LONGITUDE=-80.54
APP_TIMEZONE=America/New_York

# Printed on every report page. Example: UNCLASSIFIED//FOUO
WOR_CLASSIFICATION=UNCLASSIFIED

# Sent as the User-Agent to the National Weather Service. A contact
# address is courteous per their usage guidance.
NWS_USER_AGENT=DroneSmoke/2.0 (your-contact@example.mil)

# --- Email (optional) ---
# Leave blank to disable emailing reports. The app runs fine without it;
# reports remain downloadable in the Day tab.
SENDGRID_API_KEY=
FROM_ADDRESS=
RECIPIENT_1=
RECIPIENT_2=
RECIPIENT_3=
RECIPIENT_4=
